---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});
const publishedTime = new Date(post.data.date).toISOString();
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      '@id': `${canonicalURL}#article`,
      headline: post.data.title,
      description: post.data.description,
      datePublished: publishedTime,
      mainEntityOfPage: canonicalURL,
      image: 'https://www.facundogoni.com.ar/assets/img/og-default.png',
      author: {
        '@type': 'Person',
        '@id': 'https://www.facundogoni.com.ar/#person',
        name: 'Facundo Goñi',
        url: 'https://www.facundogoni.com.ar/',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.facundogoni.com.ar/' },
        { '@type': 'ListItem', position: 2, name: 'Notes', item: 'https://www.facundogoni.com.ar/notes' },
        { '@type': 'ListItem', position: 3, name: post.data.title, item: canonicalURL },
      ],
    },
  ],
};
---

<Layout
  title={`${post.data.title} — Facundo Goñi`}
  description={post.data.description}
  type="article"
  publishedTime={publishedTime}
  jsonLd={jsonLd}
>
  <article class="prose">
    <header class="post-header">
      <div class="eyebrow">Notes · <time datetime={post.data.date}>{formattedDate}</time></div>
      <h1>{post.data.title}</h1>
    </header>
    <Content />
  </article>

  <a href="/notes" class="back-link">← Back to notes</a>
</Layout>

<style>
  .post-header {
    margin-bottom: 40px;
  }

  .post-header .eyebrow {
    margin-bottom: 16px;
  }

  .back-link {
    display: inline-block;
    margin-top: 64px;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 160ms;
  }

  .back-link:hover { opacity: 1; }
</style>
