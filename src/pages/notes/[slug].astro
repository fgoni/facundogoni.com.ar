---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});
const publishedTime = new Date(post.data.date).toISOString();
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const socialImage = `/og/notes/${post.slug}.png`;
const socialImageURL = new URL(socialImage, Astro.site).href;
const relatedBySlug: Record<string, { title: string; href: string }[]> = {
  'jira-time-tracking-cli': [
    { title: 'Web development', href: '/services/web-development' },
    { title: 'Stations: Laravel on Vercel', href: '/projects/stations' },
  ],
  'mortgage-mission-control-from-my-phone': [
    { title: 'Mortgage Mission Control', href: '/projects/mortgage-mission-control' },
    { title: 'Rapid prototyping', href: '/services/rapid-prototyping' },
  ],
  'one-screen-for-all-my-agents': [
    { title: 'Prompting agents by voice with Hex', href: '/notes/prompting-agents-by-voice-with-hex' },
    { title: "Stop working on the 'dumb zone'", href: '/notes/stop-working-on-the-dumb-zone' },
  ],
  'prompting-agents-by-voice-with-hex': [
    { title: "One screen for all my agents", href: '/notes/one-screen-for-all-my-agents' },
    { title: 'Ghostty × Claude Code', href: '/projects/ghostty-claude-themes' },
  ],
  'stop-working-on-the-dumb-zone': [
    { title: 'One screen for all my agents', href: '/notes/one-screen-for-all-my-agents' },
    { title: 'Guiding GPT-5.6 Sol through a Vue 3 migration', href: '/notes/vue-3-migration-is-not-done-when-it-builds' },
  ],
  'vue-3-migration-is-not-done-when-it-builds': [
    { title: 'Web development and modernization', href: '/services/web-development' },
    { title: "Stop working on the 'dumb zone'", href: '/notes/stop-working-on-the-dumb-zone' },
  ],
  'gpt-5-6-sol-and-codex-artifacts': [
    { title: 'Guiding GPT-5.6 Sol through a Vue 3 migration', href: '/notes/vue-3-migration-is-not-done-when-it-builds' },
    { title: 'One screen for all my agents', href: '/notes/one-screen-for-all-my-agents' },
  ],
};
const relatedLinks = relatedBySlug[post.slug] ?? [];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      '@id': `${canonicalURL}#article`,
      headline: post.data.title,
      description: post.data.description,
      datePublished: publishedTime,
      mainEntityOfPage: canonicalURL,
      image: socialImageURL,
      author: {
        '@type': 'Person',
        '@id': 'https://www.facundogoni.com.ar/#person',
        name: 'Facundo Goñi',
        url: 'https://www.facundogoni.com.ar/',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.facundogoni.com.ar/' },
        { '@type': 'ListItem', position: 2, name: 'Notes', item: 'https://www.facundogoni.com.ar/notes' },
        { '@type': 'ListItem', position: 3, name: post.data.title, item: canonicalURL },
      ],
    },
  ],
};
---

<Layout
  title={`${post.data.title} — Facundo Goñi`}
  description={post.data.description}
  image={socialImage}
  type="article"
  publishedTime={publishedTime}
  jsonLd={jsonLd}
>
  <article class="prose">
    <header class="post-header">
      <div class="eyebrow">Notes · <time datetime={post.data.date}>{formattedDate}</time></div>
      <h1>{post.data.title}</h1>
    </header>
    <Content />

    {relatedLinks.length > 0 && (
      <aside class="related">
        <div class="related-label">Keep reading</div>
        {relatedLinks.map((link) => <a href={link.href}>{link.title} <span>→</span></a>)}
      </aside>
    )}
  </article>

  <a href="/notes" class="back-link">← Back to notes</a>
</Layout>

<style>
  .post-header {
    margin-bottom: 40px;
  }

  .post-header .eyebrow {
    margin-bottom: 16px;
  }

  .back-link {
    display: inline-block;
    margin-top: 64px;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 160ms;
  }

  .related {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .related-label {
    margin-bottom: 4px;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .related a {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    text-decoration: none;
  }

  .related a:hover { opacity: 0.65; }
  .back-link:hover { opacity: 1; }
</style>
