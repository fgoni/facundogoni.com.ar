---
import Layout from '../layouts/Layout.astro';

const description = 'Independent web and mobile developer in Buenos Aires with 20+ years of experience shipping high-quality products from idea to production.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfilePage',
      '@id': 'https://www.facundogoni.com.ar/#profile',
      url: 'https://www.facundogoni.com.ar/',
      name: 'Facundo Goñi — Web & mobile developer',
      mainEntity: { '@id': 'https://www.facundogoni.com.ar/#person' },
    },
    {
      '@type': 'Person',
      '@id': 'https://www.facundogoni.com.ar/#person',
      name: 'Facundo Goñi',
      url: 'https://www.facundogoni.com.ar/',
      image: 'https://www.facundogoni.com.ar/assets/img/8738638.jpg',
      jobTitle: 'Web & mobile developer',
      homeLocation: { '@type': 'Place', name: 'Buenos Aires, Argentina' },
      sameAs: [
        'https://github.com/fgoni',
        'https://www.linkedin.com/in/facundogoni/',
      ],
    },
  ],
};
---

<Layout title="Facundo Goñi — Web & mobile developer" description={description} jsonLd={jsonLd}>
  <section class="hero">
    <div class="hero-left">
      <div class="eyebrow">Independent developer · 20+ years shipping</div>
      <h1 class="hero-title">
        Building<br/>
        <em class="em">high-quality</em><br/>
        products,<br/>
        fast.
      </h1>
      <p class="availability">
        <span class="status-dot" aria-hidden="true"></span>
        Available for freelance &amp; consulting projects
      </p>
    </div>

    <div class="hero-right">
      <div class="rule" aria-hidden="true"></div>
      <p class="lede">
        I'm a web &amp; mobile developer focused on shipping <em class="em">high-quality</em> products fast — from idea to production.
      </p>
      <p class="bio">
        <em class="em">Over 20 years</em> in the industry — across startups, agencies, and product teams. I work the full stack, with an emphasis on rapid prototyping, clean architecture, and thoughtful UI/UX.
      </p>
      <p class="bio">
        I enjoy learning new tools and collaborating with people who care about building things well.
      </p>
      <p class="bio">
        If you're working on a product and need help bringing it to life, <a href="/contact">let's talk</a>.
      </p>
    </div>
  </section>

  <section class="now">
    <div class="eyebrow">Currently</div>
    <div class="now-item">
      <div class="now-label">Shipping</div>
      <div class="now-text"><em class="em">JSON Assistant</em> on the Mac App Store — a privacy-first JSON viewer.</div>
    </div>
    <div class="now-item">
      <div class="now-label">Studying</div>
      <div class="now-text">AWS certifications, alongside <em class="em">Certification Prep Pro</em>.</div>
    </div>
    <div class="now-item">
      <div class="now-label">Tinkering</div>
      <div class="now-text">Native macOS, CLI ergonomics, and context-engineering for LLMs.</div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 96px;
    align-items: start;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: 108px;
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-weight: 400;
    margin: 32px 0 0 0;
    text-wrap: pretty;
  }

  .availability {
    margin: 48px 0 0;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--sans);
    font-size: 13px;
    color: var(--muted);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.18);
    display: inline-block;
  }

  .hero-right {
    padding-top: 90px;
  }

  .rule {
    width: 32px;
    height: 1px;
    background: var(--rule);
    margin-bottom: 28px;
  }

  .lede {
    font-family: var(--serif);
    font-size: 21px;
    line-height: 1.55;
    margin: 0 0 28px;
    text-wrap: pretty;
  }

  .bio {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.7;
    color: var(--muted);
    margin: 0 0 28px;
  }

  .bio:last-child { margin-bottom: 0; }

  .bio a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .bio a:hover { opacity: 0.7; }

  .now {
    margin-top: 104px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 180px 1fr 1fr 1fr;
    gap: 48px;
  }

  .now-label {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .now-text {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.5;
  }

  @media (max-width: 880px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .hero-title {
      font-size: 64px;
      margin-top: 24px;
    }

    .hero-right {
      padding-top: 0;
    }

    .availability { margin-top: 32px; }

    .now {
      margin-top: 64px;
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
