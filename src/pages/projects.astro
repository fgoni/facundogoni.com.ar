---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const collection = await getCollection('projects');

const order = ['ghostty-claude-themes', 'mic-playback', 'mortgage-mission-control', 'certification-prep-pro', 'json-assistant', 'stations', 'kiosquito'];
const romans = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII'];

const overrides: Record<string, { name: string; meta: string; desc: string; tags: string[]; href: string }> = {
  'ghostty-claude-themes': {
    name: 'Ghostty × Claude Code',
    meta: 'Web · 2026',
    desc: "A theme visualizer that previews how a Claude Code session looks under every Ghostty terminal theme, painting each one with that theme's real color palette.",
    tags: ['Astro', 'Terminal Themes', 'Cloudflare Workers'],
    href: 'https://cc-themes-for-ghostty.facundogoni.com.ar/',
  },
  'mic-playback': {
    name: 'Mic Playback Lab',
    meta: 'Web · 2026',
    desc: 'A tiny browser-based microphone tester: record a short sample, play it back instantly, and watch the same VU meter react during recording and playback.',
    tags: ['Web Audio', 'Cloudflare Workers', 'Tool'],
    href: 'https://mic.facundogoni.com.ar/',
  },
  'mortgage-mission-control': {
    name: 'Mortgage Mission Control',
    meta: 'Web · 2026',
    desc: 'A lightweight dashboard for tracking an Argentine UVA mortgage, shipped as a static site on Cloudflare Workers.',
    tags: ['Dashboard', 'Cloudflare Workers', 'Personal Tool'],
    href: 'https://hipotecario.facundogoni.com.ar/',
  },
  'certification-prep-pro': {
    name: 'Certification Prep Pro',
    meta: 'iOS · macOS · 2025',
    desc: 'A focused, distraction-free study companion for AWS certification exams. 1,300+ practice questions, native on iPhone and Mac.',
    tags: ['Swift', 'iOS', 'macOS'],
    href: 'https://apps.apple.com/fi/app/certification-prep-pro/id6741158449',
  },
  'json-assistant': {
    name: 'JSON Assistant',
    meta: 'macOS · 2025',
    desc: "A fast, privacy-first JSON viewer and formatter. On-device parsing, a tree explorer, and a warm sepia theme that's easy on the eyes.",
    tags: ['Swift', 'macOS', 'Devtools'],
    href: 'https://apps.apple.com/fi/app/json-assistant/id6753915615?mt=12',
  },
  'stations': {
    name: 'Stations',
    meta: 'Web · 2024',
    desc: "A Reddit aggregator for battlestations and desk setups. Laravel running on Vercel's serverless PHP runtime — part product, part proof of concept.",
    tags: ['Laravel', 'PHP', 'Vercel'],
    href: 'https://stations.facundogoni.com.ar/',
  },
  'kiosquito': {
    name: 'Kiosquito Digital',
    meta: 'Web · 2024',
    desc: 'A digital platform built around interactive content and engagement — modern web, responsive, and built to keep people clicking through.',
    tags: ['Web', 'Platform'],
    href: 'https://kiosquito.digital/',
  },
};

const description = 'Selected web, iOS, and macOS products built and shipped by Facundo Goñi, from native developer tools to focused web applications.';

const projects = order
  .map((slug, i) => {
    const project = collection.find((p) => p.slug === slug);
    const o = overrides[slug];
    if (!project || !o) return null;
    return {
      slug: project.slug,
      n: romans[i],
      ...o,
    };
  })
  .filter((p): p is NonNullable<typeof p> => p !== null);
---

<Layout title="Work — Facundo Goñi" description={description}>
  <div class="eyebrow">Selected work</div>
  <h1 class="page-title">
    Things I've<br/><em class="em">shipped.</em>
  </h1>

  <div class="projects">
    {projects.map((p) => (
      <a href={`/projects/${p.slug}`} class="project">
        <div class="project-num">{p.n}</div>
        <div class="project-name">{p.name}</div>
        <div class="project-desc">{p.desc}</div>
        <div class="project-meta">
          <div class="project-meta-line">{p.meta}</div>
          <div class="project-tags">
            {p.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
        <div class="project-arrow" aria-hidden="true">→</div>
      </a>
    ))}
    <div class="projects-end" aria-hidden="true"></div>
  </div>
</Layout>

<style>
  .page-title {
    font-family: var(--serif);
    font-size: 72px;
    line-height: 0.95;
    letter-spacing: -0.025em;
    font-weight: 400;
    margin: 24px 0 56px;
  }

  .projects {
    display: flex;
    flex-direction: column;
  }

  .project {
    display: grid;
    grid-template-columns: 60px 1.2fr 1.4fr 220px 40px;
    gap: 28px;
    padding: 32px 0;
    border-top: 1px solid var(--rule);
    align-items: baseline;
    text-decoration: none;
    color: inherit;
    transition: opacity 220ms;
  }

  .projects:hover .project {
    opacity: 0.35;
  }

  .projects:hover .project:hover {
    opacity: 1;
  }

  .projects-end {
    border-top: 1px solid var(--rule);
  }

  .project-num {
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .project-name {
    font-family: var(--serif);
    font-size: 40px;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
    color: var(--ink);
    transition: color 220ms, font-style 220ms;
  }

  .project:hover .project-name {
    font-style: italic;
    color: var(--accent);
  }

  .project-desc {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .project-meta-line {
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--rule);
    color: var(--muted);
    opacity: 0.85;
  }

  .project-arrow {
    font-family: var(--serif);
    font-size: 18px;
    color: var(--muted);
    opacity: 0.5;
    text-align: right;
    transition: color 220ms, opacity 220ms;
  }

  .project:hover .project-arrow {
    color: var(--accent);
    opacity: 1;
  }

  @media (max-width: 880px) {
    .page-title { font-size: 48px; margin-bottom: 32px; }

    .project {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 24px 0;
    }

    .project-num {
      font-size: 11px;
      opacity: 0.7;
    }

    .project-name { font-size: 28px; }

    .project-arrow { display: none; }

    .projects:hover .project { opacity: 1; }
  }
</style>
