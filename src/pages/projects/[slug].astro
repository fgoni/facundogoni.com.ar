---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<Layout title={`${project.data.title} — Facundo Goñi`}>
  <article class="prose">
    <header class="project-header">
      <div class="eyebrow">Work {project.data.status ? `· ${project.data.status}` : ''}</div>
      <h1>{project.data.title}</h1>
      <div class="tags">
        {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </header>

    <Content />

    <div class="links">
      {project.data.appStoreUrl && (
        <a href={project.data.appStoreUrl} target="_blank" rel="noopener noreferrer">
          View on App Store ↗
        </a>
      )}
      {project.data.demoUrl && (
        <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer">
          View live site ↗
        </a>
      )}
      {project.data.githubUrl && (
        <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer">
          View on GitHub ↗
        </a>
      )}
    </div>
  </article>

  <a href="/projects" class="back-link">← Back to work</a>
</Layout>

<style>
  .project-header {
    margin-bottom: 40px;
  }

  .project-header .eyebrow {
    margin-bottom: 16px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 16px;
  }

  .tag {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--rule);
    color: var(--muted);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
  }

  .links a {
    font-family: var(--serif);
    font-size: 17px;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .links a:hover { opacity: 0.7; }

  .back-link {
    display: inline-block;
    margin-top: 64px;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 160ms;
  }

  .back-link:hover { opacity: 1; }
</style>
