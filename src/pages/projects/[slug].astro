---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const socialImage = `/og/projects/${project.slug}.png`;
const relatedURLs = [project.data.appStoreUrl, project.data.demoUrl, project.data.githubUrl].filter(Boolean);
const relatedBySlug: Record<string, { title: string; href: string }[]> = {
  'certification-prep-pro': [
    { title: 'iOS & macOS development', href: '/services/ios-macos-development' },
    { title: 'JSON Assistant', href: '/projects/json-assistant' },
  ],
  'ghostty-claude-themes': [
    { title: 'One screen for all my agents', href: '/notes/one-screen-for-all-my-agents' },
    { title: 'Prompting agents by voice with Hex', href: '/notes/prompting-agents-by-voice-with-hex' },
  ],
  'json-assistant': [
    { title: 'iOS & macOS development', href: '/services/ios-macos-development' },
    { title: 'Certification Prep Pro', href: '/projects/certification-prep-pro' },
  ],
  'kiosquito': [
    { title: 'Web development', href: '/services/web-development' },
    { title: 'Rapid prototyping', href: '/services/rapid-prototyping' },
  ],
  'mic-playback': [
    { title: 'Rapid prototyping', href: '/services/rapid-prototyping' },
    { title: 'Web development', href: '/services/web-development' },
  ],
  'mortgage-mission-control': [
    { title: 'How I shipped it entirely from my phone', href: '/notes/mortgage-mission-control-from-my-phone' },
    { title: 'Rapid prototyping', href: '/services/rapid-prototyping' },
  ],
  'stations': [
    { title: 'Web development', href: '/services/web-development' },
    { title: 'Jira time tracking on the CLI', href: '/notes/jira-time-tracking-cli' },
  ],
};
const relatedLinks = relatedBySlug[project.slug] ?? [];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': project.data.appStoreUrl ? 'SoftwareApplication' : 'CreativeWork',
      '@id': `${canonicalURL}#project`,
      name: project.data.title,
      description: project.data.description,
      url: canonicalURL,
      image: new URL(socialImage, Astro.site).href,
      keywords: project.data.tags.join(', '),
      ...(relatedURLs.length > 0 ? { sameAs: relatedURLs } : {}),
      author: {
        '@type': 'Person',
        '@id': 'https://www.facundogoni.com.ar/#person',
        name: 'Facundo Goñi',
        url: 'https://www.facundogoni.com.ar/',
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.facundogoni.com.ar/' },
        { '@type': 'ListItem', position: 2, name: 'Work', item: 'https://www.facundogoni.com.ar/projects' },
        { '@type': 'ListItem', position: 3, name: project.data.title, item: canonicalURL },
      ],
    },
  ],
};
---

<Layout
  title={`${project.data.title} — Facundo Goñi`}
  description={project.data.description}
  image={socialImage}
  jsonLd={jsonLd}
>
  <article class="prose">
    <header class="project-header">
      <div class="eyebrow">Work {project.data.status ? `· ${project.data.status}` : ''}</div>
      <h1>{project.data.title}</h1>
      <div class="tags">
        {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </header>

    <Content />

    <div class="links">
      {project.data.appStoreUrl && (
        <a href={project.data.appStoreUrl} target="_blank" rel="noopener noreferrer">
          View on App Store ↗
        </a>
      )}
      {project.data.demoUrl && (
        <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer">
          View live site ↗
        </a>
      )}
      {project.data.githubUrl && (
        <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer">
          View on GitHub ↗
        </a>
      )}
    </div>

    {relatedLinks.length > 0 && (
      <aside class="related">
        <div class="related-label">Related</div>
        {relatedLinks.map((link) => <a href={link.href}>{link.title} <span>→</span></a>)}
      </aside>
    )}
  </article>

  <a href="/projects" class="back-link">← Back to work</a>
</Layout>

<style>
  .project-header {
    margin-bottom: 40px;
  }

  .project-header .eyebrow {
    margin-bottom: 16px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 16px;
  }

  .tag {
    font-family: var(--sans);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--rule);
    color: var(--muted);
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
  }

  .links a {
    font-family: var(--serif);
    font-size: 17px;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .links a:hover { opacity: 0.7; }

  .related {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .related-label {
    margin-bottom: 4px;
    font-family: var(--sans);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .related a {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    text-decoration: none;
  }

  .related a:hover { opacity: 0.65; }

  .back-link {
    display: inline-block;
    margin-top: 64px;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 160ms;
  }

  .back-link:hover { opacity: 1; }
</style>
