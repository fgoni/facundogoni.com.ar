---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const blogPosts = await getCollection('blog');

const deks: Record<string, string> = {
  'vue-3-migration-is-not-done-when-it-builds': 'How I guided GPT-5.6 Sol in Pi through 68 browser audits, 200 form controls, visual diffs, and a hostile deployment review.',
  'mortgage-mission-control-from-my-phone': 'I shipped a whole site from the Claude Code web app on my phone, no laptop involved, hosted on Cloudflare Workers.',
  'stop-working-on-the-dumb-zone': 'Track context usage in Claude Code to stay on-plan — a small status-line tweak that pays off all day.',
  'jira-time-tracking-cli': "A small Python script to see exactly how much you've logged today, without ever opening the web UI.",
};

const reads: Record<string, string> = {
  'vue-3-migration-is-not-done-when-it-builds': '10 min',
  'mortgage-mission-control-from-my-phone': '4 min',
  'stop-working-on-the-dumb-zone': '3 min',
  'jira-time-tracking-cli': '4 min',
};

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const sortedPosts = blogPosts
  .slice()
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const description = 'Notes by Facundo Goñi on developer tools, AI-assisted workflows, product development, and the details that help software ship.';
---

<Layout title="Notes — Facundo Goñi" description={description}>
  <div class="notes">
    <aside class="intro">
      <div class="eyebrow">Notes</div>
      <h1 class="page-title">
        Thinking<br/><em class="em">out loud.</em>
      </h1>
      <p class="dek">
        Short writing on tools, workflow, and the small details that compound when you ship for a living.
      </p>
    </aside>

    <div class="list">
      {sortedPosts.map((post) => (
        <a href={`/notes/${post.slug}`} class="post">
          <div class="post-meta">
            <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
            <div class="post-read">{reads[post.slug] ?? ''}</div>
          </div>
          <div class="post-body">
            <div class="post-title">{post.data.title}</div>
            <div class="post-dek">{deks[post.slug] ?? post.data.description}</div>
          </div>
        </a>
      ))}
      <div class="list-end" aria-hidden="true"></div>
    </div>
  </div>
</Layout>

<style>
  .notes {
    display: grid;
    grid-template-columns: 1fr 2.2fr;
    gap: 96px;
  }

  .intro {
    position: sticky;
    top: 40px;
    align-self: start;
  }

  .page-title {
    font-family: var(--serif);
    font-size: 64px;
    line-height: 0.95;
    letter-spacing: -0.025em;
    font-weight: 400;
    margin: 24px 0 28px;
  }

  .dek {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
    max-width: 320px;
  }

  .list {
    display: flex;
    flex-direction: column;
  }

  .post {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 32px;
    padding: 32px 0;
    border-top: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
    transition: opacity 200ms;
  }

  .post:hover {
    opacity: 0.7;
  }

  .list-end {
    border-top: 1px solid var(--rule);
  }

  .post-meta {
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--muted);
    padding-top: 8px;
  }

  .post-read {
    margin-top: 4px;
    opacity: 0.7;
  }

  .post-title {
    font-family: var(--serif);
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.015em;
    font-weight: 400;
  }

  .post-dek {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
    font-style: italic;
    margin-top: 10px;
  }

  @media (max-width: 880px) {
    .notes {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .intro { position: static; }
    .page-title { font-size: 44px; }
    .post {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .post-title { font-size: 22px; }
  }
</style>
