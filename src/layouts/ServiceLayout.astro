---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  serviceType: string;
  slug: string;
}

const { title, description, serviceType, slug } = Astro.props;
const url = `https://www.facundogoni.com.ar/services/${slug}/`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: title,
      description,
      serviceType,
      url,
      provider: {
        '@type': 'Person',
        '@id': 'https://www.facundogoni.com.ar/#person',
        name: 'Facundo Goñi',
      },
      areaServed: 'Worldwide',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.facundogoni.com.ar/' },
        { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://www.facundogoni.com.ar/services/' },
        { '@type': 'ListItem', position: 3, name: title, item: url },
      ],
    },
  ],
};
---

<Layout title={`${title} — Facundo Goñi`} description={description} jsonLd={jsonLd}>
  <article class="service-page">
    <header>
      <div class="eyebrow">Services</div>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
    </header>

    <div class="service-content prose">
      <slot />
    </div>

    <aside class="service-cta">
      <div>
        <div class="eyebrow">Have a project in mind?</div>
        <p>Tell me what you're building, where it stands, and what you need.</p>
      </div>
      <a href="/contact">Let's talk →</a>
    </aside>
  </article>

  <a href="/services" class="back-link">← Back to services</a>
</Layout>

<style>
  .service-page { max-width: 880px; }

  header { max-width: 760px; }

  h1 {
    margin: 24px 0 24px;
    font-family: var(--serif);
    font-size: clamp(52px, 7vw, 88px);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 0.98;
  }

  .lede {
    max-width: 680px;
    margin: 0;
    color: var(--muted);
    font-size: 21px;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .service-content { margin-top: 64px; }

  .service-cta {
    margin-top: 64px;
    padding: 32px 0;
    border-block: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .service-cta p {
    margin: 12px 0 0;
    font-size: 18px;
  }

  .service-cta a,
  .back-link {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    flex: none;
    font-family: var(--sans);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .service-cta a { border-bottom: 1px solid var(--ink); }
  .service-cta a:active, .back-link:active { transform: scale(0.96); }

  .back-link {
    margin-top: 48px;
    opacity: 0.65;
  }

  .back-link:hover { opacity: 1; }

  @media (max-width: 680px) {
    h1 { font-size: 46px; }
    .service-content { margin-top: 48px; }
    .service-cta { align-items: flex-start; flex-direction: column; }
  }
</style>
